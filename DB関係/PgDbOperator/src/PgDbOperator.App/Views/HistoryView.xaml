<UserControl x:Class="PgDbOperator.Views.HistoryView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="2*"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="実行履歴" FontSize="24" FontWeight="Bold" Margin="0,0,20,0" />
            <Button Content="再読込" Command="{Binding RefreshCommand}" />
        </StackPanel>
        <DataGrid Grid.Row="1" ItemsSource="{Binding Histories}" SelectedItem="{Binding SelectedHistory}" AutoGenerateColumns="False" Margin="0,12,0,4" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="開始日時" Binding="{Binding StartedAt}" Width="160" />
                <DataGridTextColumn Header="操作" Binding="{Binding OperationType}" Width="110" />
                <DataGridTextColumn Header="結果" Binding="{Binding Result}" Width="90" />
                <DataGridTextColumn Header="アプリ" Binding="{Binding ApplicationName}" Width="160" />
                <DataGridTextColumn Header="接続" Binding="{Binding ConnectionName}" Width="130" />
                <DataGridTextColumn Header="DB" Binding="{Binding DatabaseName}" Width="130" />
                <DataGridTextColumn Header="対象ファイル" Binding="{Binding TargetFilePath}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
        <GroupBox Grid.Row="2" Header="詳細">
            <Grid DataContext="{Binding SelectedHistory}">
                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <TextBlock Text="コマンド"/><TextBox Grid.Column="1" Text="{Binding CommandText}" IsReadOnly="True" TextWrapping="Wrap" />
                <TextBlock Grid.Row="1" Text="ログファイル"/><TextBox Grid.Row="1" Grid.Column="1" Text="{Binding LogFilePath}" IsReadOnly="True" />
                <TextBlock Grid.Row="2" Text="メッセージ"/><TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Message}" IsReadOnly="True" TextWrapping="Wrap" />
                <TextBlock Grid.Row="3" Text="標準エラー"/><TextBox Grid.Row="3" Grid.Column="1" Text="{Binding StandardError}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
