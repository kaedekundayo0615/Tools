<UserControl x:Class="PgDbOperator.Views.PostgresClientsView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="PostgreSQLクライアント設定" FontSize="24" FontWeight="Bold" Margin="0,0,20,0" />
            <Button Content="追加" Command="{Binding AddCommand}" />
            <Button Content="bin反映" Command="{Binding ApplyBinCommand}" />
            <Button Content="保存" Command="{Binding SaveCommand}" />
            <Button Content="削除" Command="{Binding DeleteCommand}" />
        </StackPanel>
        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="3*"/></Grid.ColumnDefinitions>
            <DataGrid ItemsSource="{Binding Clients}" SelectedItem="{Binding SelectedClient}" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="設定名" Binding="{Binding Name}" Width="2*" />
                    <DataGridTextColumn Header="バージョン" Binding="{Binding Version}" Width="*" />
                    <DataGridCheckBoxColumn Header="標準" Binding="{Binding IsDefault}" Width="70" />
                </DataGrid.Columns>
            </DataGrid>
            <GroupBox Grid.Column="1" Header="詳細">
                <Grid DataContext="{Binding SelectedClient}">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="設定名"/><TextBox Grid.Column="1" Text="{Binding Name}"/>
                    <TextBlock Grid.Row="1" Text="バージョン"/><TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Version}"/>
                    <TextBlock Grid.Row="2" Text="binフォルダ"/><TextBox Grid.Row="2" Grid.Column="1" Text="{Binding BinDirectory}"/>
                    <TextBlock Grid.Row="3" Text="pg_dump"/><TextBox Grid.Row="3" Grid.Column="1" Text="{Binding PgDumpPath}"/>
                    <TextBlock Grid.Row="4" Text="pg_restore"/><TextBox Grid.Row="4" Grid.Column="1" Text="{Binding PgRestorePath}"/>
                    <TextBlock Grid.Row="5" Text="psql"/><TextBox Grid.Row="5" Grid.Column="1" Text="{Binding PsqlPath}"/>
                    <TextBlock Grid.Row="6" Text="デフォルト"/><CheckBox Grid.Row="6" Grid.Column="1" IsChecked="{Binding IsDefault}"/>
                    <TextBlock Grid.Row="7" Text="説明"/><TextBox Grid.Row="7" Grid.Column="1" Text="{Binding Description}"/>
                </Grid>
            </GroupBox>
        </Grid>
        <TextBlock Grid.Row="2" Text="{Binding Message}" Foreground="DarkGreen" />
    </Grid>
</UserControl>
