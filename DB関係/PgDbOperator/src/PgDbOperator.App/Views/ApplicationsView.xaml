<UserControl x:Class="PgDbOperator.Views.ApplicationsView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="対象アプリ管理" FontSize="24" FontWeight="Bold" Margin="0,0,20,0" />
            <Button Content="追加" Command="{Binding AddCommand}" />
            <Button Content="保存" Command="{Binding SaveCommand}" />
            <Button Content="削除" Command="{Binding DeleteCommand}" />
        </StackPanel>
        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="3*"/></Grid.ColumnDefinitions>
            <DataGrid ItemsSource="{Binding Applications}" SelectedItem="{Binding SelectedApplication}" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="アプリ名" Binding="{Binding Name}" Width="2*" />
                    <DataGridTextColumn Header="種別" Binding="{Binding ApplicationType}" Width="*" />
                    <DataGridCheckBoxColumn Header="有効" Binding="{Binding IsEnabled}" Width="70" />
                </DataGrid.Columns>
            </DataGrid>
            <GroupBox Grid.Column="1" Header="詳細">
                <Grid DataContext="{Binding SelectedApplication}">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="アプリ名"/><TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Grid.Row="1" Text="種別"/><ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding DataContext.ApplicationTypes, RelativeSource={RelativeSource AncestorType=UserControl}}" SelectedItem="{Binding ApplicationType}" />
                    <TextBlock Grid.Row="2" Text="標準バックアップ先"/><TextBox Grid.Row="2" Grid.Column="1" Text="{Binding DefaultBackupDirectory, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Grid.Row="3" Text="標準SQLフォルダ"/><TextBox Grid.Row="3" Grid.Column="1" Text="{Binding DefaultSqlDirectory, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Grid.Row="4" Text="有効"/><CheckBox Grid.Row="4" Grid.Column="1" IsChecked="{Binding IsEnabled}" />
                    <TextBlock Grid.Row="5" Text="説明"/><TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Description}" AcceptsReturn="True" TextWrapping="Wrap" />
                </Grid>
            </GroupBox>
        </Grid>
        <TextBlock Grid.Row="2" Text="{Binding Message}" Foreground="DarkGreen" />
    </Grid>
</UserControl>
