<UserControl x:Class="PgDbOperator.Views.SqlExecutionView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <TextBlock Text="SQL実行" FontSize="24" FontWeight="Bold" />
        <StackPanel Grid.Row="1">
            <GroupBox Header="実行対象"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <TextBlock Text="対象アプリ"/><ComboBox Grid.Column="1" ItemsSource="{Binding Applications}" SelectedItem="{Binding SelectedApplication}" DisplayMemberPath="Name" />
                <TextBlock Grid.Row="1" Text="DB接続"/><ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding Connections}" SelectedItem="{Binding SelectedConnection}" />
                <TextBlock Grid.Row="2" Text="PostgreSQL設定"/><ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding Clients}" SelectedItem="{Binding SelectedClient}" />
                <TextBlock Grid.Row="3" Text="パスワード"/><TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Password}" />
            </Grid></GroupBox>
            <GroupBox Header="SQL読込"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <TextBlock Text="SQLフォルダ"/><TextBox Grid.Column="1" Text="{Binding SqlDirectory}"/><Button Grid.Column="2" Content="読込" Command="{Binding LoadDirectoryCommand}" />
                <TextBlock Grid.Row="1" Text="SQLファイル追加"/><TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ManualSqlFile}"/><Button Grid.Row="1" Grid.Column="2" Content="追加" Command="{Binding AddManualSqlCommand}" />
                <TextBlock Grid.Row="2" Text="失敗時動作"/><ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding FailureBehaviors}" SelectedItem="{Binding FailureBehavior}" />
            </Grid></GroupBox>
        </StackPanel>
        <DataGrid Grid.Row="2" ItemsSource="{Binding SqlFiles}" AutoGenerateColumns="False" Margin="4">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="実行" Binding="{Binding IsSelected}" Width="70" />
                <DataGridTextColumn Header="ファイル名" Binding="{Binding FileName}" Width="2*" IsReadOnly="True" />
                <DataGridTextColumn Header="パス" Binding="{Binding FilePath}" Width="4*" IsReadOnly="True" />
                <DataGridTextColumn Header="サイズ" Binding="{Binding SizeBytes}" Width="100" IsReadOnly="True" />
                <DataGridTextColumn Header="更新日時" Binding="{Binding UpdatedAt}" Width="160" IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <Button Content="選択SQLを実行" Command="{Binding ExecuteCommand}" />
            <TextBlock Text="{Binding Message}" Margin="12,8,0,0" TextWrapping="Wrap" Foreground="DarkGreen" />
        </StackPanel>
    </Grid>
</UserControl>
