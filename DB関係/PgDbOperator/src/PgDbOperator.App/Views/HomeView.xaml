<UserControl x:Class="PgDbOperator.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- ホーム画面専用色定義：添付画面に合わせた白背景＋黒ヘッダー＋グレー一覧 -->
        <SolidColorBrush x:Key="HomeBackgroundBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="HomeTitleBrush" Color="#FF003366" />
        <SolidColorBrush x:Key="HomeGridHeaderBrush" Color="#FF000000" />
        <SolidColorBrush x:Key="HomeGridHeaderTextBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="HomeGridBodyBrush" Color="#FFD9D9D9" />
        <SolidColorBrush x:Key="HomeGridLineBrush" Color="#FFB8C7D9" />
        <SolidColorBrush x:Key="HomeGridBorderBrush" Color="#FF0B294A" />

        <!-- セクションタイトル -->
        <Style x:Key="HomeSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource HomeTitleBrush}" />
            <Setter Property="FontFamily" Value="Meiryo UI" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <!-- 説明文 -->
        <Style x:Key="HomeDescriptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF111111" />
            <Setter Property="FontFamily" Value="Meiryo UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,20" />
        </Style>

        <!-- 一覧ヘッダー -->
        <Style x:Key="HomeDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource HomeGridHeaderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource HomeGridHeaderTextBrush}" />
            <Setter Property="FontFamily" Value="Meiryo UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="BorderBrush" Value="{StaticResource HomeGridLineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>

        <!-- 一覧セル -->
        <Style x:Key="HomeDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Background" Value="{StaticResource HomeGridBodyBrush}" />
            <Setter Property="Foreground" Value="#FF111111" />
            <Setter Property="FontFamily" Value="Meiryo UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="BorderBrush" Value="{StaticResource HomeGridLineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFBFCBE0" />
                    <Setter Property="Foreground" Value="#FF000000" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 一覧行 -->
        <Style x:Key="HomeDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="{StaticResource HomeGridBodyBrush}" />
            <Setter Property="MinHeight" Value="24" />
        </Style>

        <!-- 一覧共通 -->
        <Style x:Key="HomeDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserReorderColumns" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="All" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource HomeGridLineBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource HomeGridLineBrush}" />
            <Setter Property="Background" Value="{StaticResource HomeGridBodyBrush}" />
            <Setter Property="RowBackground" Value="{StaticResource HomeGridBodyBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{StaticResource HomeGridBodyBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource HomeGridBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource HomeDataGridColumnHeaderStyle}" />
            <Setter Property="CellStyle" Value="{StaticResource HomeDataGridCellStyle}" />
            <Setter Property="RowStyle" Value="{StaticResource HomeDataGridRowStyle}" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource HomeBackgroundBrush}" Margin="16,14,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="3*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="3*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="登録アプリ一覧"
                   Style="{StaticResource HomeSectionTitleStyle}" />

        <TextBlock Grid.Row="1"
                   Text="登録済みのアプリと直近のDB操作履歴を確認します。"
                   Style="{StaticResource HomeDescriptionStyle}" />

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Applications}"
                  Style="{StaticResource HomeDataGridStyle}"
                  MinHeight="240">
            <DataGrid.Columns>
                <DataGridTextColumn Header="アプリ名" Binding="{Binding Name}" Width="2*" />
                <DataGridTextColumn Header="種別" Binding="{Binding ApplicationType}" Width="*" />
                <DataGridTextColumn Header="標準バックアップ先" Binding="{Binding DefaultBackupDirectory}" Width="3*" />
                <DataGridCheckBoxColumn Header="有効" Binding="{Binding IsEnabled}" Width="90" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3"
                   Text="実行履歴"
                   Style="{StaticResource HomeSectionTitleStyle}"
                   Margin="0,22,0,8" />

        <DataGrid Grid.Row="4"
                  ItemsSource="{Binding RecentHistories}"
                  Style="{StaticResource HomeDataGridStyle}"
                  MinHeight="260">
            <DataGrid.Columns>
                <DataGridTextColumn Header="開始日時" Binding="{Binding StartedAt, StringFormat=yyyy/MM/dd HH:mm:ss}" Width="140" />
                <DataGridTextColumn Header="アプリ名" Binding="{Binding ApplicationName}" Width="2*" />
                <DataGridTextColumn Header="操作" Binding="{Binding OperationType}" Width="90" />
                <DataGridTextColumn Header="結果" Binding="{Binding Result}" Width="90" />
                <DataGridTextColumn Header="DB" Binding="{Binding DatabaseName}" Width="120" />
                <DataGridTextColumn Header="標準バックアップ先" Binding="{Binding TargetFilePath}" Width="3*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
