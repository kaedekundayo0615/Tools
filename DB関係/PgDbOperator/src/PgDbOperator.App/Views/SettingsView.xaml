<UserControl x:Class="PgDbOperator.Views.SettingsView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer><StackPanel Margin="16">
        <TextBlock Text="アプリ設定" FontSize="24" FontWeight="Bold" />
        <GroupBox Header="既定値"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <TextBlock Text="既定バックアップ先"/><TextBox Grid.Column="1" Text="{Binding DefaultBackupDirectory}" />
            <TextBlock Grid.Row="1" Text="既定SQLフォルダ"/><TextBox Grid.Row="1" Grid.Column="1" Text="{Binding DefaultSqlDirectory}" />
            <TextBlock Grid.Row="2" Text="ログ保持日数"/><TextBox Grid.Row="2" Grid.Column="1" Text="{Binding LogRetentionDays}" />
        </Grid></GroupBox>
        <GroupBox Header="安全設定"><StackPanel>
            <CheckBox Content="リストア前バックアップを推奨する" IsChecked="{Binding RequireBackupBeforeRestore}" />
            <CheckBox Content="本番環境の操作時に警告する" IsChecked="{Binding RequireWarningForProduction}" />
            <CheckBox Content="危険SQLを検出して警告する" IsChecked="{Binding WarnDangerousSql}" />
        </StackPanel></GroupBox>
        <Button Content="保存" Command="{Binding SaveCommand}" HorizontalAlignment="Left" />
        <TextBlock Text="{Binding Message}" Foreground="DarkGreen" />
    </StackPanel></ScrollViewer>
</UserControl>
