<Window x:Class="PgDbOperator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PgDbOperator - PostgreSQL DB運用支援ツール"
        Height="820"
        Width="1280"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- 共通色：収支内訳APPのサイドメニューを参考にした黒基調デザイン -->
        <SolidColorBrush x:Key="BrushRootBg" Color="#FF141414"/>
        <SolidColorBrush x:Key="BrushTopBg"  Color="#FF0F0F0F"/>
        <SolidColorBrush x:Key="BrushBorder" Color="#FF373737"/>
        <SolidColorBrush x:Key="BrushHover"  Color="#FF1E1E1E"/>
        <SolidColorBrush x:Key="BrushDown"   Color="#FF232323"/>
        <SolidColorBrush x:Key="BrushText"   Color="White"/>
        <SolidColorBrush x:Key="BrushSelectedBg" Color="#FF2A2A2A"/>
        <SolidColorBrush x:Key="BrushSelectedBorder" Color="#FF7A6A2A"/>
        <SolidColorBrush x:Key="BrushSelectedText" Color="#FFF8E8A6"/>
        <SolidColorBrush x:Key="BrushMainBg" Color="#FFF7F7F7"/>

        <!-- タイトル用（金系グラデーション） -->
        <LinearGradientBrush x:Key="BrushAppTitle" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FFF6E27A" Offset="0.00"/>
            <GradientStop Color="#FFD6B54B" Offset="0.50"/>
            <GradientStop Color="#FFF8E8A6" Offset="1.00"/>
        </LinearGradientBrush>

        <!-- サイドメニューボタン共通スタイル -->
        <Style x:Key="MenuButtonBaseStyle" TargetType="Button">
            <Setter Property="Height" Value="56"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,0,0,0"/>
            <Setter Property="FontFamily" Value="Yu Gothic UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BrushHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource BrushDown}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ヘッダー折りたたみボタン -->
        <Style x:Key="HeaderButtonStyle" TargetType="Button" BasedOn="{StaticResource MenuButtonBaseStyle}">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>

        <!-- セクション見出し -->
        <Style x:Key="MenuSectionTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF9A9A9A"/>
            <Setter Property="FontFamily" Value="Yu Gothic UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="16,14,0,6"/>
            <Setter Property="Visibility" Value="{Binding MenuTextVisibility}"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BrushMainBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding SideMenuWidth}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 左：サイドメニュー -->
        <Grid Grid.Column="0" Background="{StaticResource BrushRootBg}">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 上部：アプリタイトル＋トグル -->
            <Grid Grid.Row="0" Background="{StaticResource BrushTopBg}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="56"/>
                </Grid.ColumnDefinitions>

                <Button Grid.ColumnSpan="2"
                        Style="{StaticResource HeaderButtonStyle}"
                        Command="{Binding ToggleSideMenuCommand}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="56"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="1"
                                   Text="≡"
                                   Foreground="{StaticResource BrushText}"
                                   FontFamily="Yu Gothic UI"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Grid>
                </Button>

                <TextBlock Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Text="PgDbOperator"
                           Foreground="{StaticResource BrushAppTitle}"
                           FontFamily="Yu Gothic UI"
                           FontSize="17"
                           FontWeight="ExtraBold"
                           VerticalAlignment="Center"
                           Margin="22,0,38,0"
                           Visibility="{Binding TitleTextVisibility}"
                           IsHitTestVisible="False">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="0" Opacity="0.55"/>
                    </TextBlock.Effect>
                </TextBlock>
            </Grid>

            <!-- メニュー -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,8,0,0">
                <StackPanel Background="{StaticResource BrushRootBg}">
                    <TextBlock Text="MAIN" Style="{StaticResource MenuSectionTextStyle}"/>

                    <Button Command="{Binding NavigateHomeCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MenuButtonBaseStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentMenuKey}" Value="Home">
                                        <Setter Property="Background" Value="{StaticResource BrushSelectedBg}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectedBorder}"/>
                                        <Setter Property="Foreground" Value="{StaticResource BrushSelectedText}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏠" Width="28" FontSize="16"/>
                            <TextBlock Text="ホーム" TextWrapping="NoWrap" Visibility="{Binding MenuTextVisibility}"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateApplicationsCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MenuButtonBaseStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentMenuKey}" Value="Applications">
                                        <Setter Property="Background" Value="{StaticResource BrushSelectedBg}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectedBorder}"/>
                                        <Setter Property="Foreground" Value="{StaticResource BrushSelectedText}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🧩" Width="28" FontSize="16"/>
                            <TextBlock Text="対象アプリ管理" TextWrapping="NoWrap" Visibility="{Binding MenuTextVisibility}"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateDbConnectionsCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MenuButtonBaseStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentMenuKey}" Value="DbConnections">
                                        <Setter Property="Background" Value="{StaticResource BrushSelectedBg}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectedBorder}"/>
                                        <Setter Property="Foreground" Value="{StaticResource BrushSelectedText}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔌" Width="28" FontSize="16"/>
                            <TextBlock Text="DB接続管理" TextWrapping="NoWrap" Visibility="{Binding MenuTextVisibility}"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigatePostgresClientsCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MenuButtonBaseStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentMenuKey}" Value="PostgresClients">
                                        <Setter Property="Background" Value="{StaticResource BrushSelectedBg}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectedBorder}"/>
                                        <Setter Property="Foreground" Value="{StaticResource BrushSelectedText}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🐘" Width="28" FontSize="16"/>
                            <TextBlock Text="PostgreSQL設定" TextWrapping="NoWrap" Visibility="{Binding MenuTextVisibility}"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Text="OPERATION" Style="{StaticResource MenuSectionTextStyle}"/>

                    <Button Command="{Binding NavigateBackupCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MenuButtonBaseStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentMenuKey}" Value="Backup">
                                        <Setter Property="Background" Value="{StaticResource BrushSelectedBg}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectedBorder}"/>
                                        <Setter Property="Foreground" Value="{StaticResource BrushSelectedText}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" Width="28" FontSize="16"/>
                            <TextBlock Text="バックアップ" TextWrapping="NoWrap" Visibility="{Binding MenuTextVisibility}"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateRestoreCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MenuButtonBaseStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentMenuKey}" Value="Restore">
                                        <Setter Property="Background" Value="{StaticResource BrushSelectedBg}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectedBorder}"/>
                                        <Setter Property="Foreground" Value="{StaticResource BrushSelectedText}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="♻️" Width="28" FontSize="16"/>
                            <TextBlock Text="リストア" TextWrapping="NoWrap" Visibility="{Binding MenuTextVisibility}"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateSqlExecutionCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MenuButtonBaseStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentMenuKey}" Value="SqlExecution">
                                        <Setter Property="Background" Value="{StaticResource BrushSelectedBg}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectedBorder}"/>
                                        <Setter Property="Foreground" Value="{StaticResource BrushSelectedText}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📝" Width="28" FontSize="16"/>
                            <TextBlock Text="SQL実行" TextWrapping="NoWrap" Visibility="{Binding MenuTextVisibility}"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateDataReplaceCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MenuButtonBaseStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentMenuKey}" Value="DataReplace">
                                        <Setter Property="Background" Value="{StaticResource BrushSelectedBg}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectedBorder}"/>
                                        <Setter Property="Foreground" Value="{StaticResource BrushSelectedText}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" Width="28" FontSize="16"/>
                            <TextBlock Text="データ入れ替え" TextWrapping="NoWrap" Visibility="{Binding MenuTextVisibility}"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Text="SYSTEM" Style="{StaticResource MenuSectionTextStyle}"/>

                    <Button Command="{Binding NavigateHistoryCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MenuButtonBaseStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentMenuKey}" Value="History">
                                        <Setter Property="Background" Value="{StaticResource BrushSelectedBg}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectedBorder}"/>
                                        <Setter Property="Foreground" Value="{StaticResource BrushSelectedText}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" Width="28" FontSize="16"/>
                            <TextBlock Text="実行履歴" TextWrapping="NoWrap" Visibility="{Binding MenuTextVisibility}"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateSettingsCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MenuButtonBaseStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentMenuKey}" Value="Settings">
                                        <Setter Property="Background" Value="{StaticResource BrushSelectedBg}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectedBorder}"/>
                                        <Setter Property="Foreground" Value="{StaticResource BrushSelectedText}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️" Width="28" FontSize="16"/>
                            <TextBlock Text="アプリ設定" TextWrapping="NoWrap" Visibility="{Binding MenuTextVisibility}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- 右：メイン領域 -->
        <Border Grid.Column="1" Background="White">
            <ContentControl Content="{Binding CurrentView}" />
        </Border>
    </Grid>
</Window>
